        <?php if (count($posts) > 0): ?>
            <?php foreach (array_slice($posts, 0, 6) as $post): ?>
                <?php
                $content = file_get_contents($post);
                $title = pathinfo($post, PATHINFO_FILENAME);
                if (preg_match('/<title>(.*?)</title>/i', $content, $matches)) {
                    $title = htmlspecialchars_decode(trim($matches[1]));
                }
                $date = date('Y年m月d日', filemtime($post));
                $excerpt = substr(strip_tags($content), 0, 150) . '...';
                ?>
                <a href="post.php?file=<?= urlencode(basename($post)) ?>" class="card">
                    <div class="card-title"><?= htmlspecialchars($title) ?></div>
                    <div class="card-date"><?= $date ?></div>
                    <div class="card-excerpt"><?= htmlspecialchars($excerpt) ?></div>
                    <div class="card-actions">
                        <span class="chip" style="pointer-events: none;">阅读更多 →</span>
                    </div>
                </a>
            <?php endforeach; ?>
        <?php else: ?>
            <div class="empty">
                <h2>暂无文章</h2>
                <p>快来写下你的第一篇文章吧！</p>
                <a href="create_post.php" class="tile active" style="display: inline-flex; margin-top: 16px; padding: 12px 24px;">
                    <span class="tile-label">立即发布</span>
                </a>
            </div>
        <?php endif; ?>
