    <div id="notice-dialog" class="dialog-overlay">
        <div class="dialog">
            <div class="dialog-header">
                <h3 class="dialog-title">公告通知</h3>
                <button class="dialog-close" onclick="closeNotice()">×</button>
            </div>
            <div class="dialog-body">
                <p>如今，官网已经使用kali api key 完善了key 接口测试</p>
                <p><small>公告时间：<?php echo date('Y年m月d日'); ?></small></p>
            </div>
            <div class="dialog-footer">
                <button class="chip" onclick="dismissNotice()">不再显示</button>
                <button class="chip active" onclick="closeNotice()">我知道了</button>
            </div>
        </div>
    </div>

    <script src="js/script.js"></script>
    <script>
        function closeNotice() {
            document.getElementById('notice-dialog').classList.remove('show');
            localStorage.setItem('noticeDismissed', 'true');
            localStorage.setItem('noticeDismissTime', Date.now());
        }

        function dismissNotice() {
            document.getElementById('notice-dialog').classList.remove('show');
            localStorage.setItem('noticeDismissed', 'true');
            localStorage.setItem('noticeDismissTime', Date.now());
            localStorage.setItem('noticeDismissLong', 'true');
        }

        document.addEventListener('DOMContentLoaded', function() {
            const noticeDismissed = localStorage.getItem('noticeDismissed');
            const dismissTime = parseInt(localStorage.getItem('noticeDismissTime') || '0');
            const currentTime = Date.now();
            const hours24 = 24 * 60 * 60 * 1000;
            const days7 = 7 * 24 * 60 * 60 * 1000;

            if (noticeDismissed === 'true') {
                const timeDiff = currentTime - dismissTime;
                const isLong = localStorage.getItem('noticeDismissLong') === 'true';
                const threshold = isLong ? days7 : hours24;
                if (timeDiff < threshold) {
                    document.getElementById('notice-dialog').classList.remove('show');
                } else {
                    localStorage.removeItem('noticeDismissed');
                    localStorage.removeItem('noticeDismissTime');
                    localStorage.removeItem('noticeDismissLong');
                }
            }

            setTimeout(() => {
                document.getElementById('notice-dialog').classList.add('show');
            }, 1000);
        });
    </script>
</body>
</html>
